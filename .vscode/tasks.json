{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Listen HTML/CSS Change",
            "type": "shell",
            "command": "npx tailwindcss -i ./src/input.css -o ./src/output.css --watch",
            "group": "build",
            "problemMatcher": [],
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "label": "Push To Github Folder",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-Command",
                "Remove-Item -Path '${workspaceFolder}/../XINICOM.github.io/' -Recurse -Force\nCopy-Item -Path '${workspaceFolder}\\src\\*' -Destination '${workspaceFolder}/../XINICOM.github.io/' -Recurse -Force"
            ],
            "group": "build",
            "problemMatcher": [],
            "options": {
                "cwd": "${workspaceFolder}"
            }
        }
    ],
    "inputs": [
        {
            "id": "gitFolder",
            "type": "command",
            "command": "shellCommand.execute",
            "args": {
                "command": "dir /ad /b",
                "cwd": "${workspaceFolder}/../",
                "defaultFormatter": "${workspaceFolder}/../XINICOM.github.io/"
            }
        }
    ]
}
